mode=release #release

# Kite API bind address.
KITE_HTTP_ADDR=:8080

# JWT signing secret for /api/login accessToken. Use a long random value in production.
KITE_JWT_SECRET=change-me-to-a-long-random-secret

# Password hashing salt. Use a long random value in production.
KITE_PASSWORD_SALT=change-me-to-a-long-random-salt

# Temporary admin login credentials for /api/login until database-backed auth is implemented.
KITE_ADMIN_USERNAME=admin
KITE_ADMIN_PASSWORD=admin

# Real Kubernetes store integration tests are opt-in because they create and delete cluster resources.
# Run them from the terminal like this:
# KITE_STORE_INTEGRATION_TEST=1 go test ./internal/store -run TestStoreCRUDWithRealClient -v
