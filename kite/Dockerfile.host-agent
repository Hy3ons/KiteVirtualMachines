FROM golang:1.25-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/kite-host-agent ./cmd/kite-host-agent

FROM alpine:3.22

RUN apk add --no-cache openssh-client util-linux

COPY --from=build /out/kite-host-agent /kite-host-agent

ENTRYPOINT ["/kite-host-agent"]
