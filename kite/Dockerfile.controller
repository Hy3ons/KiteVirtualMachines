FROM golang:1.25-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/kite-controller ./cmd/kite-controller

FROM alpine:3.22

RUN addgroup -S kite && adduser -S kite -G kite
USER kite

COPY --from=build /out/kite-controller /kite-controller

ENTRYPOINT ["/kite-controller"]
