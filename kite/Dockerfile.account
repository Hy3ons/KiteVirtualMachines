FROM golang:1.25-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/kite-account ./cmd/kite-account

FROM alpine:3.22

RUN apk add --no-cache util-linux

COPY --from=build /out/kite-account /kite-account

ENTRYPOINT ["/kite-account"]
