{
  "name": "kite-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "VITE_API_BASE_URL=${VITE_API_BASE_URL:-http://localhost:8080/api/v1} VITE_USE_MOCK=${VITE_USE_MOCK:-true} VITE_DEBUG_DIRECT_ROUTES=${VITE_DEBUG_DIRECT_ROUTES:-true} vite --mode debug --host 127.0.0.1 --port 5173",
    "stage": "VITE_API_BASE_URL=${VITE_API_BASE_URL:-http://localhost:8080/api/v1} VITE_USE_MOCK=${VITE_USE_MOCK:-false} vite --mode staging",
    "typecheck": "tsc -b",
    "build": "npm run typecheck && vite build",
    "build:dev": "VITE_API_BASE_URL=${VITE_API_BASE_URL:-http://localhost:8080/api/v1} VITE_USE_MOCK=${VITE_USE_MOCK:-true} npm run build -- --mode debug",
    "guard:release-mock": "node -e \"if (process.env.VITE_USE_MOCK === 'true') { console.error('VITE_USE_MOCK=true is not allowed for staging or production builds'); process.exit(1); }\"",
    "build:stage": "npm run guard:release-mock && VITE_API_BASE_URL=${VITE_API_BASE_URL:-http://localhost:8080/api/v1} VITE_USE_MOCK=${VITE_USE_MOCK:-false} npm run build -- --mode staging",
    "build:prod": "npm run guard:release-mock && VITE_API_BASE_URL=${VITE_API_BASE_URL:-/api/v1} VITE_USE_MOCK=${VITE_USE_MOCK:-false} npm run build -- --mode production",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "antd": "^6.4.3",
    "axios": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.16.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
